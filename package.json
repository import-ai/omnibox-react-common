{
  "name": "@omnibox/react-common",
  "version": "0.1.0",
  "description": "Omnibox React Common SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "omnibox",
    "react",
    "chat",
    "streaming"
  ],
  "author": "Lucien Shui",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "socket.io-client": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  }
}
